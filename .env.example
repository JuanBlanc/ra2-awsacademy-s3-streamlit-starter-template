# Configuracion AWS - Copia este archivo a .env y rellena los valores
# IMPORTANTE: No subas el archivo .env al repositorio

# Region de AWS donde esta el bucket (ej: us-east-1, us-west-1, eu-west-1)
AWS_REGION=us-east-1

# Nombre del bucket S3 (sin s3://)
S3_BUCKET=juancho-sensores

# Ruta del archivo JSON dentro del bucket
S3_KEY=data/sensores/iabd11_sensores.json

# Credenciales AWS (obtener de AWS Academy -> AWS Details -> Show)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
